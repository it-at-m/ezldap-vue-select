{
  "name": "@muenchen/ezldap-vue-select",
  "version": "1.0.0",
  "description": "Vue.js/Vuetify component `ldap-person-auswahl` for a LDAP-based person search and selection",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/it-at-m/ezldap-vue-select.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/ezldap-vue-select.umd.cjs",
  "types": "./dist/components/index.d.ts",
  "module": "./dist/ezldap-vue-select.js",
  "exports": {
    ".": {
      "import": "./dist/ezldap-vue-select.js",
      "require": "./dist/ezldap-vue-select.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
    "build:demo": "vue-tsc && vite build -c vite.demo.config.ts",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "preview": "vite preview",
    "semantic-release": "semantic-release",
    "lint": "eslint . --fix",
    "cy:run": "cypress run --component"
  },
  "peerDependencies": {
    "@mdi/font": "^7.4.47",
    "vue": "^3.5.32",
    "vuetify": "^3.12.5"
  },
  "devDependencies": {
    "@muenchen/prettier-codeformat": "1.0.2",
    "@tsconfig/node-lts": "24.0.0",
    "@types/node": "24.11.2",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/coverage-v8": "^3.1.4",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.1",
    "cypress": "^15.0.0",
    "eslint": "10.2.0",
    "eslint-plugin-vue": "10.8.0",
    "eslint-plugin-vuetify": "^2.0.1",
    "jsdom": "^27.0.0",
    "path": "^0.12.7",
    "prettier": "^3.0.0",
    "sass": "~1.99.0",
    "semantic-release": "^25.0.2",
    "typescript": "^5.0.0",
    "vite": "8.0.9",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vuetify": "^2.1.1",
    "vitest": "^3.1.4",
    "vue-tsc": "^3.0.0"
  },
  "engines": {
    "node": ">=24.11 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
