{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "declarations.d.ts",
    "route-map.d.ts",
    "src/**/*",
    "src/**/*.vue"
  ],
  "exclude": [
    "src/**/*.cy.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "tests/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./cache/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"],
    "moduleResolution": "bundler"
  }
}
